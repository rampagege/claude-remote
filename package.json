{
  "name": "tmuxfly",
  "version": "1.0.0",
  "description": "Tmux web client — remote tmux web interface to monitor and interact with AI coding agents (Claude Code, Codex) from phone, tablet, or any browser over Tailscale",
  "keywords": [
    "tmux",
    "tmux-web",
    "tmux-remote",
    "tmux-web-client",
    "tmux-web-interface",
    "tmux-mobile",
    "tmux-browser",
    "web-terminal",
    "remote-terminal",
    "tmux-viewer",
    "tmux-monitor",
    "tmux-dashboard",
    "tailscale",
    "claude-code",
    "ai-agent",
    "terminal"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Shawn",
  "repository": {
    "type": "git",
    "url": "https://github.com/rampagege/tmuxfly.git"
  },
  "homepage": "https://github.com/rampagege/tmuxfly#readme",
  "bugs": {
    "url": "https://github.com/rampagege/tmuxfly/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch --ignore './vite.config.ts.timestamp*' server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config vite.config.ts",
    "build:server": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "preview": "npm run build && npm run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'server/**/*.ts' 'client/**/*.ts' --fix",
    "format": "prettier --write '**/*.{ts,html,css,json}'",
    "prepare": "npx husky install || true"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-pty": "^1.0.0",
    "pino": "^9.4.0",
    "selfsigned": "^5.5.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "pino-pretty": "^11.2.0",
    "postcss": "^8.4.41",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
