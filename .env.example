# Server configuration
PORT=3980
HOST=127.0.0.1

# Authentication token (required)
AUTH_TOKEN=your-secret-token-here

# AI Supervisor (monitors tmux sessions via LLM)
# Provider: openrouter (default), openai, minimax
# SUPERVISOR_PROVIDER=openrouter
# SUPERVISOR_ENABLED=true
# SUPERVISOR_POLL_MS=5000
# SUPERVISOR_MAX_LINES=80
#
# API key — set the key for your chosen provider:
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# MINIMAX_API_KEY=
# Or use a universal override (takes priority over provider-specific key):
# SUPERVISOR_API_KEY=
#
# Model & base URL — auto-set per provider, override if needed:
# SUPERVISOR_MODEL=openai/gpt-4o-mini
# SUPERVISOR_BASE_URL=https://openrouter.ai/api/v1

# Notification channel: web or telegram (only one active at a time)
# SUPERVISOR_CHANNEL=web
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# HTTPS — set to true to enable (auto-generates self-signed cert)
# When enabled, both HTTP and HTTPS servers run simultaneously
HTTPS=false
# HTTPS port (default: PORT + 1)
# HTTPS_PORT=3001
# Custom TLS certificate (optional, overrides self-signed)
# TLS_KEY=/path/to/server.key
# TLS_CERT=/path/to/server.crt

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Claude CLI command (default: claude)
CLAUDE_CMD=claude

# Max concurrent tmux sessions
MAX_TMUX_SESSIONS=10
